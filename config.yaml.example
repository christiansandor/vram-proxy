# vram-proxy config.yaml
# ========================
#
# Each service needs:
#   name     - human-readable label
#   type     - plugin type: lmstudio | comfyui | openai
#   prefix   - URL namespace under /v1 (optional, default: empty)
#              Empty prefix:    routes served at /v1/<route>
#              prefix: openai:  routes served at /v1/openai/<route>
#   baseUrl  - where the service is listening
#   routes   - Upstream paths exactly as the backing service expects them.
#              The proxy derives the client-facing URL automatically:
#                route=/v1/chat/completions + prefix=openai
#                  → client hits /v1/openai/chat/completions
#                  → upstream receives /v1/chat/completions
#                route=/object_info + prefix=comfyui
#                  → client hits /v1/comfyui/object_info
#                  → upstream receives /object_info
#              Services that use /v1 natively keep it in their routes.
#              Services that don't (e.g. ComfyUI) omit it.
#
# URL structure
# -------------
# All traffic is rooted under /v1:
#
#   No prefix:    /v1/audio/speech          → upstream: /v1/audio/speech
#   prefix=openai /v1/openai/chat/completions → upstream: /v1/chat/completions
#
# The prefix is stripped before forwarding, so upstreams always receive
# their native /v1/... paths regardless of what prefix you configure here.
#
# Model discovery
# ---------------
# /v1/models              → models from services with no prefix
# /v1/<prefix>/models     → models from services with that prefix
#
# Multiple services can share the same prefix — their models and routes
# are merged under that namespace.

services:

  # ── LM Studio (LLMs) ───────────────────────────────────────────────────────
  # Served under /v1/openai/ — e.g. /v1/openai/chat/completions
  # LM Studio's plugin handles VRAM unload via its own /api/v1/models/unload.
  - name: LM Studio
    type: lmstudio
    prefix: openai
    baseUrl: http://host.docker.internal:1234
    routes:
      - /v1/chat/completions
      - /v1/completions
      - /v1/embeddings

  # ── ComfyUI (image generation) ─────────────────────────────────────────────
  # Served under /v1/comfyui/ — e.g. /v1/comfyui/prompt
  # Models are declared here (ComfyUI has no OpenAI-format list endpoint).
  # VRAM freed via POST /free.
  - name: ComfyUI
    type: comfyui
    prefix: comfyui
    baseUrl: http://host.docker.internal:8188
    models:
      - id: stable-diffusion-xl
        description: SDXL 1.0
      - id: flux-dev
        description: Flux.1 dev
    routes:
      - /prompt
      - /queue
      - /history
      - /upload
      - /view
      - /object_info

  # ── Whisper STT ─────────────────────────────────────────────────────────────
  # Also under /v1/openai/ — its models appear in /v1/openai/models alongside
  # LM Studio's.  Container-managed: stopped when not in use to free VRAM,
  # started on demand when a transcription request arrives.
  - name: Whisper
    type: openai
    prefix: openai
    baseUrl: http://host.docker.internal:8000
    container:
      name: openedai-whisper
      health_path: /health
      start_timeout: 60
      stop_timeout: 15
      ttl: 300
    routes:
      - /v1/audio/transcriptions
      - /v1/audio/translations

  # ── Kokoro TTS ──────────────────────────────────────────────────────────────
  # No prefix — served at /v1/audio/speech.
  # Its models appear in the bare /v1/models response.
  - name: Kokoro TTS
    type: openai
    prefix:
    baseUrl: http://host.docker.internal:8880
    container:
      name: kokoro-tts
      health_path: /health
      start_timeout: 45
      stop_timeout: 15
      ttl: 300
    routes:
      - /v1/audio/speech
